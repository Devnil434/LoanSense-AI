# --- Database ---
# For local development, leave unset to use local SQLite (./loansense.db).
# For production, use a cloud Postgres connection string, e.g. Neon:
DATABASE_URL=postgresql://username:password@ep-example-12345.us-east-2.aws.neon.tech/loansense?sslmode=require

# --- Auth ---
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- App ---
ENVIRONMENT=development
ML_MODEL_PATH=../ml/models/loan_model.joblib
CORS_ORIGINS=["http://localhost:3000"]
