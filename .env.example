# =========================================================
# LoanSense AI — Root environment reference
# Copy the relevant sections into backend/.env and
# frontend/.env.local respectively.
# =========================================================

# ---------- Database (backend/.env) ----------
# Neon PostgreSQL is preferred. Sign up at https://neon.tech, create a
# project, and copy the connection string below. Supabase or Aiven
# Postgres connection strings also work unchanged.
DATABASE_URL=postgresql://username:password@ep-example-12345.us-east-2.aws.neon.tech/loansense?sslmode=require

# ---------- Auth (backend/.env) ----------
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ---------- App (backend/.env) ----------
ENVIRONMENT=production
ML_MODEL_PATH=../ml/models/loan_model.joblib
CORS_ORIGINS=["https://your-frontend.vercel.app","http://localhost:3000"]

# ---------- Frontend (frontend/.env.local) ----------
NEXT_PUBLIC_API_BASE_URL=https://your-backend.onrender.com/api/v1
